{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A detailing service package offered by PureRun.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the service package." },
        "tagline": { "type": "string", "description": "Short catchy tagline." },
        "description": { "type": "string", "description": "Detailed description of what's included." },
        "price": { "type": "number", "description": "Base price for the service." },
        "icon": { "type": "string", "description": "Icon name from lucide-react." }
      },
      "required": ["name", "price"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A customer booking request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who made the booking (optional for guests)." },
        "serviceId": { "type": "string", "description": "ID of the selected service." },
        "name": { "type": "string", "description": "Customer name." },
        "email": { "type": "string", "format": "email", "description": "Customer email." },
        "phone": { "type": "string", "description": "Customer phone number." },
        "location": { "type": "string", "description": "Service location address." },
        "date": { "type": "string", "format": "date", "description": "Scheduled date." },
        "carInfo": { "type": "string", "description": "Car make and model." },
        "distance": { "type": "number", "description": "Distance from Sussex, NB in km." },
        "travelFee": { "type": "number", "description": "Calculated travel fee." },
        "total": { "type": "number", "description": "Total price including travel fee." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"], "description": "Status of the booking." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of booking." }
      },
      "required": ["serviceId", "name", "email", "date", "total"]
    },
    "Availability": {
      "title": "Availability",
      "description": "Daily availability slots.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The date for this availability." },
        "slots": { "type": "array", "items": { "type": "string" }, "description": "List of available time slots (e.g., 'Morning', 'Evening')." }
      },
      "required": ["date", "slots"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "baseLocation": { "type": "string", "description": "Base location." },
        "travelFeePerKm": { "type": "number", "description": "Fee per km beyond base." },
        "maxDistance": { "type": "number", "description": "Maximum travel distance in km." },
        "adminEmail": { "type": "string", "format": "email", "description": "Admin email for notifications." }
      },
      "required": ["baseLocation", "travelFeePerKm", "maxDistance", "adminEmail"]
    },
    "User": {
      "title": "User",
      "description": "Application user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "User email." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role." },
        "phone": { "type": "string", "description": "User's primary phone number." },
        "defaultCarInfo": { "type": "string", "description": "User's primary vehicle information." }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/services/{serviceId}": { "schema": "Service", "description": "Collection of detailing services." },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Collection of customer bookings." },
    "/availability/{date}": { "schema": "Availability", "description": "Daily availability configuration." },
    "/settings/global": { "schema": "Settings", "description": "Global business settings." },
    "/users/{userId}": { "schema": "User", "description": "Admin users." }
  }
}
